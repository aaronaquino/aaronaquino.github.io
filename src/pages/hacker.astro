---
import '../styles/experiences.scss';
import '../styles/hacker.scss';
import LearnMoreButton from '../components/LearnMoreButton.astro';
import ExperienceLayout from '../layouts/ExperienceLayout.astro';

const title = "Hacker"
const subtitle = "Highlights from my software developer journey"
---
<ExperienceLayout title={title} subtitle={subtitle}>

	<div class="experience-previews-container">
		<div class="experience-preview">
			<svg class="experience-preview-image chrome-logo" viewBox="0 0 48 48"><defs><linearGradient id="a" x1="3.2173" y1="15" x2="44.7812" y2="15" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#d93025"/><stop offset="1" stop-color="#ea4335"/></linearGradient><linearGradient id="b" x1="20.7219" y1="47.6791" x2="41.5039" y2="11.6837" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#fcc934"/><stop offset="1" stop-color="#fbbc04"/></linearGradient><linearGradient id="c" x1="26.5981" y1="46.5015" x2="5.8161" y2="10.506" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#1e8e3e"/><stop offset="1" stop-color="#34a853"/></linearGradient></defs><circle cx="24" cy="23.9947" r="12" style="fill:#fff"/><path d="M3.2154,36A24,24,0,1,0,12,3.2154,24,24,0,0,0,3.2154,36ZM34.3923,18A12,12,0,1,1,18,13.6077,12,12,0,0,1,34.3923,18Z" style="fill:none"/><path d="M24,12H44.7812a23.9939,23.9939,0,0,0-41.5639.0029L13.6079,30l.0093-.0024A11.9852,11.9852,0,0,1,24,12Z" style="fill:url(#a)"/><circle cx="24" cy="24" r="9.5" style="fill:#1a73e8"/><path d="M34.3913,30.0029,24.0007,48A23.994,23.994,0,0,0,44.78,12.0031H23.9989l-.0025.0093A11.985,11.985,0,0,1,34.3913,30.0029Z" style="fill:url(#b)"/><path d="M13.6086,30.0031,3.218,12.006A23.994,23.994,0,0,0,24.0025,48L34.3931,30.0029l-.0067-.0068a11.9852,11.9852,0,0,1-20.7778.007Z" style="fill:url(#c)"/></svg>
			<h3>Senior Software Engineer @ Google</h3>
			<h4 class="experience-subtitle">2018-Present | Kirkland, WA</h4>
			<p class="experience-description">
				I'm a front end developer on the Skills in Chrome team, helping consumers supercharge their browsing with AI-powered workflows.
			</p>
			<p class="experience-description">
				Previous teams: Chrome Web Store (Kirkland, WA) and Gmail Web (Sunnyvale, CA)
			</p>
		</div>

		<div class="experience-preview">
			<div class="experience-preview-image">
				<img src="/assets/hacker/choreoroom.png"
					srcset="/assets/hacker/choreoroom.png 742w"
					sizes="(min-width: 1200px) 220px, (min-width: 800px) 22vw, (min-width: 600px) 32vw, (min-width: 400px) 50vw, 68vw"
					alt="ChoreoRoom logo"
					class="choreoroom-logo">
			</div>
			<h3>ChoreoRoom</h3>
			<h4 class="experience-subtitle">2017-Present</h4>
			<p class="experience-description">I combined my love of dance and coding in an app to help choreographers with creating and sharing formations.</p>

			<LearnMoreButton link="/hacker/choreoroom" />
			<a class="app-store-badge-link" href="https://itunes.apple.com/us/app/choreoroom/id1332273123" target="_blank" rel="noreferrer">
				<img class="app-store-badge" src="/assets/hacker/app_store_badge.svg" alt="Download on the App Store">
			</a>
		</div>

		<div class="experience-preview">
			<div class="experience-preview-image">
				<img src="/assets/hacker/transitcat.png"
					srcset="/assets/hacker/transitcat.png 640w"
					sizes="(min-width: 1200px) 320px, (min-width: 800px) 30vw, (min-width: 550px) 45vw, 68vw"
					alt="Transitcat logo"
					class="transitcat-logo">
			</div>
			<h3>Transitcat</h3>
			<h4 class="experience-subtitle">Spring 2018 | Stanford, CA</h4>
			<p class="experience-description">My CS senior project was a digital tool for public transit planners to help them visualize and better understand their networks.</p>

			<LearnMoreButton link="/hacker/transitcat" />
		</div>
	</div>

</ExperienceLayout>
